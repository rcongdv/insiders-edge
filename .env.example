# Copy to .env.development / .env.production (picked by NODE_ENV; `npm run dev`
# loads development, `npm start` loads production). A plain `.env` file, if
# present, overrides both. All env files are gitignored except this template.

# OAuth callback URL registered with Robinhood. Use your public hostname in
# .env.production (e.g. https://your-mac.your-tailnet.ts.net/api/robinhood/callback)
# and localhost in .env.development.
ROBINHOOD_REDIRECT_URI=http://localhost:3001/api/robinhood/callback

# Other recognized variables (optional):
# PORT=3001
# ROBINHOOD_MCP_URL=https://agent.robinhood.com/mcp/trading
